{
  "realm": "datapress",
  "enabled": true,
  "accessTokenLifespan": 3600,
  "sslRequired": "none",
  "registrationAllowed": false,
  "clientScopes": [
    {
      "name": "datasets:read",
      "description": "Read datasets",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "datasets:reload",
      "description": "Reload datasets",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    }
  ],
  "clients": [
    {
      "clientId": "datapress-api",
      "name": "DataPress API",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "datapress-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:8000/*",
        "http://localhost:3000/*"
      ],
      "webOrigins": ["*"],
      "attributes": {
        "access.token.lifespan": "3600"
      },
      "defaultClientScopes": [
        "web-origins",
        "profile",
        "roles",
        "email",
        "datasets:read"
      ],
      "optionalClientScopes": [
        "datasets:reload",
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    },
    {
      "clientId": "datapress-swagger",
      "name": "DataPress Swagger UI",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost:8000/swagger-ui/*",
        "http://localhost:8000/*"
      ],
      "webOrigins": ["*"],
      "defaultClientScopes": [
        "web-origins",
        "profile",
        "roles",
        "email",
        "datasets:read"
      ],
      "optionalClientScopes": [
        "datasets:reload",
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    }
  ],
  "users": [
    {
      "username": "alice",
      "enabled": true,
      "emailVerified": true,
      "email": "alice@example.com",
      "firstName": "Alice",
      "lastName": "Example",
      "credentials": [
        { "type": "password", "value": "alice", "temporary": false }
      ],
      "realmRoles": ["default-roles-datapress"]
    }
  ]
}
