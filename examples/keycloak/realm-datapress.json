{
  "realm": "datapress",
  "enabled": true,
  "accessTokenLifespan": 3600,
  "sslRequired": "none",
  "registrationAllowed": false,
  "clientScopes": [
    {
      "name": "profile",
      "description": "OpenID Connect built-in scope: profile",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      },
      "protocolMappers": [
        {
          "name": "username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "username",
            "claim.name": "preferred_username",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "full name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-full-name-mapper",
          "consentRequired": false,
          "config": {
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "datasets:read",
      "description": "Read datasets",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "datasets:reload",
      "description": "Reload datasets",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "datasets:accidents:read",
      "description": "Read the accidents dataset",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "datasets:accidents:reload",
      "description": "Reload the accidents dataset",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "datasets:events:read",
      "description": "Read the events dataset",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "datasets:events:reload",
      "description": "Reload the events dataset",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    }
  ],
  "clients": [
    {
      "clientId": "datapress-api",
      "name": "DataPress API",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "datapress-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:8000/*",
        "http://localhost:3000/*"
      ],
      "webOrigins": ["*"],
      "attributes": {
        "access.token.lifespan": "3600"
      },
      "defaultClientScopes": [
        "web-origins",
        "profile",
        "roles",
        "email",
        "datasets:read"
      ],
      "optionalClientScopes": [
        "datasets:reload",
        "datasets:accidents:read",
        "datasets:accidents:reload",
        "datasets:events:read",
        "datasets:events:reload",
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    },
    {
      "clientId": "datapress-swagger",
      "name": "DataPress Swagger UI",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost:8000/swagger-ui/*",
        "http://localhost:8000/*"
      ],
      "webOrigins": ["*"],
      "defaultClientScopes": [
        "web-origins",
        "profile",
        "roles",
        "email",
        "datasets:read"
      ],
      "optionalClientScopes": [
        "datasets:reload",
        "datasets:accidents:read",
        "datasets:accidents:reload",
        "datasets:events:read",
        "datasets:events:reload",
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    }
  ],
  "users": [
    {
      "username": "alice",
      "enabled": true,
      "emailVerified": true,
      "email": "alice@example.com",
      "firstName": "Alice",
      "lastName": "Example",
      "credentials": [
        { "type": "password", "value": "alice", "temporary": false }
      ],
      "realmRoles": ["default-roles-datapress"]
    }
  ]
}
